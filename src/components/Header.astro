---
const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between h-20">
    <a href="/" class="flex items-center">
      <img src="/images/logo.png" alt="WorkSapien" class="h-7 md:h-9 transition-all duration-300 brightness-0 invert" id="header-logo" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-[13px] font-medium tracking-[0.12em] uppercase transition-colors duration-200 header-link",
            currentPath === link.href
              ? "text-secondary"
              : "text-white/70 hover:text-white",
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="#book"
        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/worksapien/30min'});return false;"
        class="bg-secondary text-white px-6 py-2.5 rounded-full text-[13px] font-semibold hover:bg-secondary/90 transition-all duration-200 tracking-wide hover:shadow-lg hover:shadow-secondary/20"
      >
        Book a Free Call
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-white header-link"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-lg border-t border-sage/30 shadow-xl">
    <div class="px-6 py-6 flex flex-col gap-5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-[13px] font-medium tracking-[0.12em] uppercase",
            currentPath === link.href ? "text-secondary" : "text-primary",
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="#book"
        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/worksapien/30min'});return false;"
        class="bg-secondary text-white px-6 py-3 rounded-full text-[13px] font-semibold text-center"
      >
        Book a Free Call
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });

  // Header scroll behavior: transparent on dark hero, solid on scroll
  const header = document.getElementById("site-header");
  const logo = document.getElementById("header-logo");
  const links = document.querySelectorAll(".header-link");

  function updateHeader() {
    if (window.scrollY > 80) {
      header?.classList.add("bg-white/95", "backdrop-blur-lg", "shadow-sm");
      header?.classList.remove("bg-transparent");
      logo?.classList.remove("brightness-0", "invert");
      links.forEach(l => {
        l.classList.remove("text-white/70", "hover:text-white", "text-white");
        l.classList.add("text-text-muted", "hover:text-primary");
      });
    } else {
      header?.classList.remove("bg-white/95", "backdrop-blur-lg", "shadow-sm");
      header?.classList.add("bg-transparent");
      logo?.classList.add("brightness-0", "invert");
      links.forEach(l => {
        l.classList.remove("text-text-muted", "hover:text-primary");
        l.classList.add("text-white/70", "hover:text-white");
      });
    }
  }

  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });

  // Scroll reveal observer
  const revealEls = document.querySelectorAll("[data-reveal], [data-reveal-stagger]");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("revealed");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -60px 0px" }
  );
  revealEls.forEach((el) => observer.observe(el));
</script>

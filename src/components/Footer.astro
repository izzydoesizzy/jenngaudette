---
const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary">
  <!-- Upper footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 py-20">
    <div class="grid md:grid-cols-12 gap-12">
      <!-- Brand — wider -->
      <div class="md:col-span-5">
        <img src={`${base}images/logo.png`} alt="WorkSapien" class="h-8 brightness-0 invert mb-5" />
        <p class="text-white/40 text-[15px] leading-relaxed max-w-sm">
          Integrated career and health coaching for mid-career professionals ready to transform their relationship with work.
        </p>
        <p class="font-serif text-white/20 text-lg mt-4 italic">Humanity at work.</p>
      </div>

      <!-- Quick links -->
      <div class="md:col-span-3 md:col-start-7">
        <h4 class="text-[11px] font-semibold tracking-[0.2em] uppercase text-white/30 mb-5">Navigate</h4>
        <nav class="flex flex-col gap-3">
          <a href={base} class="text-white/50 hover:text-white text-[15px] transition-colors duration-200">Home</a>
          <a href={`${base}about`} class="text-white/50 hover:text-white text-[15px] transition-colors duration-200">About Jenn</a>
          <a href={`${base}contact`} class="text-white/50 hover:text-white text-[15px] transition-colors duration-200">Contact</a>
          <a
            href="#book"
            onclick="Calendly.initPopupWidget({url: 'https://calendly.com/worksapien/30min'});return false;"
            class="text-secondary hover:text-secondary/80 text-[15px] transition-colors duration-200 font-medium"
          >
            Book a Free Call
          </a>
        </nav>
      </div>

      <!-- Contact -->
      <div class="md:col-span-3">
        <h4 class="text-[11px] font-semibold tracking-[0.2em] uppercase text-white/30 mb-5">Get in Touch</h4>
        <div class="flex flex-col gap-3 text-[15px] text-white/50">
          <a href="mailto:jennifer@worksapien.com" class="hover:text-white transition-colors duration-200">
            jennifer@worksapien.com
          </a>
          <a href="tel:+14164357769" class="hover:text-white transition-colors duration-200">
            +1 (416) 435-7769
          </a>
          <p class="text-white/30">Guelph, Ontario, Canada</p>
          <div class="flex gap-4 mt-2">
            <a href="https://www.linkedin.com/company/worksapien/" target="_blank" rel="noopener" class="text-white/30 hover:text-white transition-colors duration-200" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href="https://www.instagram.com/worksapien/" target="_blank" rel="noopener" class="text-white/30 hover:text-white transition-colors duration-200" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.06]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-6 text-center text-white/25 text-xs tracking-wide">
      <p>&copy; {currentYear} WorkSapien. All rights reserved.</p>
    </div>
  </div>
</footer>

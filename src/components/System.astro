---
const outcomes = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>`,
    title: "Career Clarity",
    description: "Realign with what matters most. Figure out who you are now and what you want next.",
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/></svg>`,
    title: "Health & Wellbeing",
    description: "Take better care of yourself without sacrificing career growth. Sustainable performance starts here.",
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/></svg>`,
    title: "Bold Action",
    description: "Initiate a new career chapter designed by and for you. Move forward with expanded capacity.",
  },
];
---

<section class="bg-primary py-24 md:py-32 relative overflow-hidden">
  <!-- Decorative circles -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] opacity-[0.03]">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-80 h-80 rounded-full border-2 border-white"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 rounded-full border-2 border-white"></div>
    <div class="absolute bottom-0 right-0 w-80 h-80 rounded-full border-2 border-white"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-6 lg:px-12">
    <div class="text-center max-w-2xl mx-auto mb-20">
      <p class="text-secondary font-semibold text-xs tracking-[0.2em] uppercase mb-4">The WorkSapien Approach</p>
      <h2 class="font-serif text-3xl md:text-[2.5rem] text-white leading-tight mb-6">
        Where career strategy meets human sustainability
      </h2>
      <p class="text-white/50 text-lg leading-relaxed">
        Work is a powerful influence on every area of wellbeing. It can elevate or deteriorate what you value most in life. The WorkSapien system integrates career coaching with health coaching to create lasting change.
      </p>
    </div>

    <!-- Venn diagram — refined -->
    <div class="relative max-w-sm mx-auto mb-20 aspect-square hidden md:block">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-52 h-52 rounded-full bg-secondary/10 border border-secondary/20 flex items-start justify-center pt-14">
        <span class="text-white/60 text-sm tracking-widest uppercase font-medium">Career</span>
      </div>
      <div class="absolute bottom-8 left-4 w-52 h-52 rounded-full bg-white/5 border border-white/10 flex items-end justify-center pb-14">
        <span class="text-white/60 text-sm tracking-widest uppercase font-medium">Health</span>
      </div>
      <div class="absolute bottom-8 right-4 w-52 h-52 rounded-full bg-white/5 border border-white/10 flex items-end justify-center pb-14">
        <span class="text-white/60 text-sm tracking-widest uppercase font-medium">Values</span>
      </div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/4 text-center">
        <span class="font-serif text-secondary text-base">You, thriving</span>
      </div>
    </div>

    <!-- Outcomes -->
    <div class="grid md:grid-cols-3 gap-px bg-white/5 rounded-2xl overflow-hidden">
      {outcomes.map((outcome) => (
        <div class="bg-primary p-10 text-center group hover:bg-white/[0.03] transition-colors duration-300">
          <div class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mx-auto mb-6 text-secondary group-hover:bg-secondary/10 group-hover:border-secondary/20 transition-all duration-300">
            <Fragment set:html={outcome.icon} />
          </div>
          <h3 class="font-serif text-xl text-white mb-3">{outcome.title}</h3>
          <p class="text-white/50 leading-relaxed text-[15px]">{outcome.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

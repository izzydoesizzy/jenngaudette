---
const credentials = [
  {
    abbr: "MCC",
    title: "Master Certified Coach",
    org: "International Coaching Federation",
    detail: "Top 3% of ICF-credentialed coaches worldwide. 200+ hours of coach education, 2,500+ hours of client coaching.",
    highlight: true,
  },
  {
    abbr: "BHC",
    title: "Board Certified Health Coach",
    org: "National Board for Health & Wellness Coaching",
    detail: "Certified to integrate health and wellness strategies into career coaching.",
  },
  {
    abbr: "CDP",
    title: "Career Development Practitioner",
    org: "Professional Certification",
    detail: "Specialized expertise in career counseling and professional development.",
  },
  {
    abbr: "MES",
    title: "Master of Environmental Studies",
    org: "Graduate Degree",
    detail: "Systems thinking and environmental behaviour change, applied to workplace wellbeing.",
  },
];

const experience = [
  {
    role: "Career Transition Consultant",
    org: "Gallagher (Arthur J. Gallagher & Co.)",
    detail: "Corporate outplacement and workforce transformation at a global HR consulting firm.",
  },
  {
    role: "Career Coach in Residence",
    org: "Toronto Public Library (2020-2021)",
    detail: "One of four inaugural coaches selected to provide pro bono career coaching, supported by the RBC Foundation.",
  },
  {
    role: "Facilitator",
    org: "Canada Coach Academy",
    detail: "Teaching and facilitating within ICF-accredited coaching education programs.",
  },
];
---

<section class="bg-cream py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6 lg:px-12">
    <div class="text-center max-w-2xl mx-auto mb-20">
      <p class="text-secondary font-semibold text-xs tracking-[0.2em] uppercase mb-4">Credentials & Experience</p>
      <h2 class="font-serif text-3xl md:text-[2.5rem] text-primary leading-tight">
        The expertise behind the coaching
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-16 max-w-5xl mx-auto">
      <!-- Credentials -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.2em] uppercase text-text-muted mb-8">Certifications</h3>
        <div class="space-y-4">
          {credentials.map((c) => (
            <div class:list={[
              "rounded-xl p-6 transition-all duration-200",
              c.highlight
                ? "bg-primary text-white shadow-lg"
                : "bg-white border border-sage/50 hover:shadow-md",
            ]}>
              <div class="flex items-start gap-4">
                <div class:list={[
                  "w-12 h-12 rounded-lg flex items-center justify-center font-serif text-lg flex-shrink-0",
                  c.highlight ? "bg-secondary text-white" : "bg-sage/60 text-primary",
                ]}>
                  {c.abbr}
                </div>
                <div class="min-w-0">
                  <h4 class:list={[
                    "font-semibold text-[15px]",
                    c.highlight ? "text-white" : "text-primary",
                  ]}>{c.title}</h4>
                  <p class:list={[
                    "text-[11px] font-medium uppercase tracking-[0.15em] mt-0.5",
                    c.highlight ? "text-secondary" : "text-secondary",
                  ]}>{c.org}</p>
                  <p class:list={[
                    "text-sm mt-2 leading-relaxed",
                    c.highlight ? "text-white/60" : "text-text-muted",
                  ]}>{c.detail}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Experience -->
      <div>
        <h3 class="text-xs font-semibold tracking-[0.2em] uppercase text-text-muted mb-8">Experience</h3>
        <div class="space-y-4">
          {experience.map((e) => (
            <div class="bg-white rounded-xl p-6 border border-sage/50 hover:shadow-md transition-all duration-200">
              <h4 class="font-semibold text-primary text-[15px]">{e.role}</h4>
              <p class="text-[11px] text-secondary font-medium uppercase tracking-[0.15em] mt-0.5">{e.org}</p>
              <p class="text-text-muted text-sm mt-2 leading-relaxed">{e.detail}</p>
            </div>
          ))}

          <!-- Podcast callout — distinct treatment -->
          <div class="relative bg-white rounded-xl p-6 border border-secondary/20 overflow-hidden">
            <div class="absolute top-0 right-0 w-20 h-20 bg-secondary/5 rounded-bl-[40px]"></div>
            <div class="relative">
              <div class="flex items-center gap-2 mb-3">
                <svg class="w-4 h-4 text-secondary" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3zm0 18a7 7 0 0 1-7-7H3a9 9 0 0 0 8 8.94V23h2v-2.06A9 9 0 0 0 21 12h-2a7 7 0 0 1-7 7z"/></svg>
                <p class="text-[11px] text-secondary font-semibold uppercase tracking-[0.15em]">Featured On</p>
              </div>
              <h4 class="font-semibold text-primary text-[15px]">CCA "What?" Podcast</h4>
              <p class="text-text-muted text-sm mt-1.5 leading-relaxed">
                Episode 10: Burnout, exhaustion, and finding your coaching mission. Hosted by Nathalie Blais (ICF MCC).
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

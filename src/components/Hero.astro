<section class="relative min-h-screen flex items-center bg-primary overflow-hidden">
  <!-- Subtle background texture -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-12 pt-28 pb-32 md:pt-36 md:pb-40 grid md:grid-cols-12 gap-12 lg:gap-16 items-center">
    <!-- Text — wider column -->
    <div class="md:col-span-7 lg:col-span-6">
      <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/10 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 rounded-full bg-secondary animate-pulse"></span>
        <span class="text-white/70 text-xs font-medium tracking-widest uppercase">Career & Health Coaching</span>
      </div>

      <h1 class="font-serif text-4xl md:text-5xl lg:text-[3.5rem] xl:text-6xl text-white leading-[1.1] mb-8">
        Transform work from a source of depletion into a source of
        <span class="text-secondary">wellbeing</span>
      </h1>

      <p class="text-white/60 text-lg md:text-xl leading-relaxed mb-10 max-w-xl">
        For mid-career professionals, leaders, and executives ready to realign their work with their values, health, and full potential.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#book"
          onclick="Calendly.initPopupWidget({url: 'https://calendly.com/worksapien/30min'});return false;"
          class="group bg-secondary text-white px-8 py-4 rounded-full text-base font-semibold hover:bg-secondary/90 transition-all hover:shadow-lg hover:shadow-secondary/20 text-center inline-flex items-center justify-center gap-2"
        >
          Book a Free 30-Minute Call
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href="#programs"
          class="border border-white/20 text-white/80 px-8 py-4 rounded-full text-base font-semibold hover:bg-white/5 hover:border-white/30 transition-all text-center"
        >
          Explore Programs
        </a>
      </div>
    </div>

    <!-- Image — tighter column -->
    <div class="md:col-span-5 lg:col-span-6 relative">
      <div class="relative">
        <!-- Decorative frame -->
        <div class="absolute -inset-3 rounded-2xl border border-white/10"></div>
        <div class="rounded-2xl overflow-hidden shadow-2xl ring-1 ring-white/10">
          <img
            src="/images/jenn.jpg"
            alt="Jenn Gaudette, Master Certified Coach"
            class="w-full aspect-[3/4] object-cover"
            style="object-position: center 30%;"
          />
          <!-- Subtle gradient overlay at bottom -->
          <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-primary/60 to-transparent"></div>
        </div>

        <!-- Floating credential badge -->
        <div class="absolute -bottom-6 left-6 right-6 bg-white/95 backdrop-blur-md rounded-xl shadow-xl px-6 py-4 flex items-center justify-between">
          <div>
            <p class="text-[10px] text-text-muted uppercase tracking-[0.2em] font-medium">ICF Credential</p>
            <p class="font-serif text-2xl text-primary -mt-0.5">MCC</p>
          </div>
          <div class="w-px h-10 bg-sage"></div>
          <div class="text-right">
            <p class="text-[10px] text-text-muted uppercase tracking-[0.2em] font-medium">Worldwide Rank</p>
            <p class="font-serif text-2xl text-secondary -mt-0.5">Top 3%</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trust bar -->
  <div class="absolute bottom-0 left-0 right-0 bg-white/[0.04] backdrop-blur-sm border-t border-white/[0.06]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-5 flex flex-wrap justify-center gap-x-10 gap-y-2 text-[13px] text-white/50 font-medium tracking-wide">
      <span>Master Certified Coach (MCC)</span>
      <span class="hidden sm:inline text-white/20">|</span>
      <span>20+ Years Experience</span>
      <span class="hidden sm:inline text-white/20">|</span>
      <span>2,500+ Coaching Hours</span>
      <span class="hidden sm:inline text-white/20">|</span>
      <span>Board Certified Health Coach</span>
    </div>
  </div>
</section>

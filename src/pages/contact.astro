---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact | WorkSapien"
  description="Book a free 30-minute introductory call with Jenn Gaudette or get in touch via email or phone."
>
  <Header />

  <main>
    <!-- Hero — dark -->
    <section class="bg-primary pt-32 pb-20 md:pt-40 md:pb-24 relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.02]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      <div class="relative max-w-3xl mx-auto px-6 lg:px-12 text-center">
        <p class="text-secondary font-semibold text-xs tracking-[0.2em] uppercase mb-6">Get in Touch</p>
        <h1 class="font-serif text-4xl md:text-5xl lg:text-[3.5rem] text-white leading-[1.1] mb-6">
          Let's talk about what's next for you
        </h1>
        <p class="text-white/50 text-lg md:text-xl leading-relaxed max-w-xl mx-auto">
          Book a free 30-minute introductory call. No pressure, no pitch. Just an honest conversation.
        </p>
      </div>
    </section>

    <!-- Calendly embed -->
    <section class="bg-cream py-16 md:py-20">
      <div class="max-w-4xl mx-auto px-6 lg:px-12">
        <div
          class="calendly-inline-widget rounded-2xl overflow-hidden shadow-lg"
          data-url="https://calendly.com/worksapien/30min"
          style="min-width:320px;height:700px;"
        ></div>
      </div>
    </section>

    <!-- Contact info + form -->
    <section class="bg-white py-24 md:py-32">
      <div class="max-w-6xl mx-auto px-6 lg:px-12">
        <div class="grid md:grid-cols-2 gap-16">
          <!-- Contact form -->
          <div>
            <p class="text-secondary font-semibold text-xs tracking-[0.2em] uppercase mb-4">Message</p>
            <h2 class="font-serif text-2xl md:text-3xl text-primary mb-8">Send a message</h2>
            <form action="https://formspree.io/f/placeholder" method="POST" class="space-y-5">
              <div>
                <label for="name" class="block text-[13px] font-medium text-text mb-2">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-5 py-3.5 rounded-xl border border-sage bg-cream/50 text-text focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary/50 transition-all text-[15px]"
                />
              </div>
              <div>
                <label for="email" class="block text-[13px] font-medium text-text mb-2">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-5 py-3.5 rounded-xl border border-sage bg-cream/50 text-text focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary/50 transition-all text-[15px]"
                />
              </div>
              <div>
                <label for="subject" class="block text-[13px] font-medium text-text mb-2">Subject</label>
                <input
                  type="text"
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-5 py-3.5 rounded-xl border border-sage bg-cream/50 text-text focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary/50 transition-all text-[15px]"
                />
              </div>
              <div>
                <label for="message" class="block text-[13px] font-medium text-text mb-2">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-5 py-3.5 rounded-xl border border-sage bg-cream/50 text-text focus:outline-none focus:ring-2 focus:ring-secondary/20 focus:border-secondary/50 transition-all resize-y text-[15px]"
                ></textarea>
              </div>
              <button
                type="submit"
                class="group bg-secondary text-white px-8 py-3.5 rounded-full font-semibold hover:bg-secondary/90 transition-all duration-200 hover:shadow-lg hover:shadow-secondary/20 inline-flex items-center gap-2"
              >
                Send Message
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
            </form>
          </div>

          <!-- Contact details -->
          <div>
            <p class="text-secondary font-semibold text-xs tracking-[0.2em] uppercase mb-4">Direct</p>
            <h2 class="font-serif text-2xl md:text-3xl text-primary mb-8">Or reach out directly</h2>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-xl bg-sage/60 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-primary text-[15px]">Email</p>
                  <a href="mailto:jennifer@worksapien.com" class="text-secondary hover:underline text-[15px]">jennifer@worksapien.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-xl bg-sage/60 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-primary text-[15px]">Phone</p>
                  <a href="tel:+14164357769" class="text-secondary hover:underline text-[15px]">+1 (416) 435-7769</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-xl bg-sage/60 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-primary text-[15px]">Location</p>
                  <p class="text-text-muted text-[15px]">Guelph, Ontario, Canada</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-11 h-11 rounded-xl bg-sage/60 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-primary text-[15px]">LinkedIn</p>
                  <a href="https://www.linkedin.com/in/jenngaudette" target="_blank" rel="noopener" class="text-secondary hover:underline text-[15px]">linkedin.com/in/jenngaudette</a>
                </div>
              </div>
            </div>

            <!-- Photo -->
            <div class="mt-10 rounded-2xl overflow-hidden shadow-sm ring-1 ring-sage/50">
              <img
                src="/images/hero-ledge.jpg"
                alt="WorkSapien coaching"
                class="w-full aspect-[3/2] object-cover"
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

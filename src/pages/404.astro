---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Page Not Found | WorkSapien">
  <Header />

  <main class="bg-primary min-h-screen flex items-center justify-center pt-20">
    <div class="max-w-xl mx-auto px-6 text-center py-24">
      <!-- Decorative element -->
      <div class="relative inline-block mb-10">
        <span class="font-serif text-[140px] md:text-[180px] leading-none text-white/[0.04] select-none">404</span>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-20 h-20 rounded-full bg-secondary/10 border border-secondary/20 flex items-center justify-center">
            <svg class="w-8 h-8 text-secondary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
          </div>
        </div>
      </div>

      <h1 class="font-serif text-3xl md:text-4xl text-white mb-4">
        Looks like you've taken a wrong turn
      </h1>
      <p class="text-white/50 text-lg leading-relaxed mb-10 max-w-md mx-auto">
        That's okay. Sometimes the best career moves start with getting a little lost. Let's get you back on track.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="group bg-secondary text-white px-8 py-4 rounded-full text-base font-semibold hover:bg-secondary/90 transition-all hover:shadow-lg hover:shadow-secondary/20 inline-flex items-center justify-center gap-2"
        >
          Back to Home
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href="#book"
          onclick="Calendly.initPopupWidget({url: 'https://calendly.com/worksapien/30min'});return false;"
          class="border border-white/20 text-white/80 px-8 py-4 rounded-full text-base font-semibold hover:bg-white/5 hover:border-white/30 transition-all text-center"
        >
          Book a Free Call Instead
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
